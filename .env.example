# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=123456:REPLACE_WITH_BOT_TOKEN

# Telegram ID владельцев бота (через запятую)
OWNER_IDS=123456789

# Имя бота (для генерации реф-ссылок)
BOT_USERNAME=YourBotUsername

# HTTPS URL мини-апки. Для локального теста сюда вставляется актуальный Pinggy URL.
WEBAPP_URL=https://your-domain.example

# Optional hidden userbot trust boost (Telethon)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
USERBOT_SESSION_PATH=userbot.session
